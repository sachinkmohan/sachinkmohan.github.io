---
import type { CollectionEntry } from "astro:content";
import { formatDate } from "../utils/formatDate";

interface Props {
  post: CollectionEntry<"til">;
}

const { post } = Astro.props;
---

<div class="til-card">
  <a class="border-b-2 text-h5 border-indigo-500" href={`/til/${post.id}`}
    >{post.data.title}</a
  >
  <div class="metadata">
    <p class="text-gray-600">
      {formatDate(post.data.date)}
    </p>
    {post.data.tags && post.data.tags.length > 0 && (
      <>
        <span class="vertical-separator"></span>
        <p class="flex gap-2">
          {post.data.tags.map((tag) => <span class="tag-badge">{tag}</span>)}
        </p>
      </>
    )}
  </div>
  {post.data.description && <p class="description">{post.data.description}</p>}
</div>

<style>
  .til-card {
    .metadata {
      display: flex;
      gap: 30px;
      align-items: center;

      .vertical-separator {
        width: 1px;
        height: 30px;
        background-color: var(--dark);
      }

      @media screen and (max-width: 600px) {
        & {
          flex-direction: column;
          gap: 2px;
          align-items: start;
          margin-bottom: 10px;
          margin-top: 16px;

          * {
            margin: 0;
          }

          .vertical-separator {
            height: 0;
            display: none;
          }
        }
      }
    }

    .description {
      font-size: 16px;
      color: var(--dark);
      margin-top: 8px;
      margin-bottom: 40px;
    }
  }
</style>
